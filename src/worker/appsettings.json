{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  },
  "ConnectionStrings": {
    "ServiceBusConnection": "${SERVICE_BUS_CONNECTION_STRING}"
  },
  "ServiceBus": {
    "QueueName": "sbq-dv-pilot-ipaas-si-01",
    "MaxDeliveryCount": 3,
    "MaxConcurrentCalls": 10,
    "ReceiveMode": "PeekLock"
  },
  "ApplicationInsights": {
    "InstrumentationKey": "${APPINSIGHTS_INSTRUMENTATION_KEY}"
  },
  "Worker": {
    "ProcessingTimeoutMs": 30000,
    "RetryDelayMs": 1000
  }
}
